@model Book



@section title {
    @if (Model != null)
    {
        <h3>Book Section</h3>
    }
}

@if (Model != null)
{
    <form method="post" asp-controller="Books" asp-action="Edit">
        <div asp-validation-summary="All" class="text-danger"></div>
        <label asp-for="Title"></label>
        <input asp-for="@Model.Title" readonly><br><br>

        <label asp-for="@Model.Author"></label>
        <input asp-for="@Model.Author">
        <span asp-validation-for="@Model.Author" class="text-danger"></span>
        <br><br>

        <label asp-for="@Model.Price"></label>
        <input asp-for="@Model.Price">
        <span asp-validation-for="@Model.Price" class="text-danger"></span>
        <br><br>


        <label asp-for="@Model.IsAvailable"></label>
        <input asp-for="@Model.IsAvailable"><br><br>
        <input type="submit" value="Submit">
    </form>
}
else
{
    <p>Nothing to display</p>
}

