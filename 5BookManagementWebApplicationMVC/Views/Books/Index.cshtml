
@model List<Book>



@if (Model != null & Model.Count > 0)
{
    <h1>Books Section</h1>
}

<table class="table">
    <thead>
        <tr>
            <th scope="col">Title</th>
            <th scope="col">Author</th>
            <th scope="col">Price</th>
            <th scope="col">IsAvailable</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var book in Model)
        {
            <tr>
                <td>@book.Title</td>
                <td>@book.Author</td>
                <td>@book.Price</td>
                <td>@book.IsAvailable</td>
                <td><a asp-controller="Books" asp-action="Edit" asp-route-id="@book.Id">Edit</a></td>
            </tr>
        }
    </tbody>
</table>
